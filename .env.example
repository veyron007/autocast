# AutoCast configuration — copy to `.env` for local dev. NEVER commit `.env`.
# In production, these come from GitHub Actions Secrets (see .github/workflows/daily.yml).
# The --dry-run skeleton needs NONE of these.

# ---- LLM cascade: gemini -> groq -> cloudflare -> cerebras ----
GEMINI_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=

# ---- Cloudflare Workers AI (LLM + image fallback). Bills on overage:
#      keep CLOUDFLARE_BUDGET_CENTS at 0 to forbid paid fallback until you set a budget.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_BUDGET_CENTS=0

# ---- Assets ----
PIXABAY_API_KEY=
PEXELS_API_KEY=
FREESOUND_API_KEY=

# ---- YouTube OAuth (Desktop client + ONE refresh token). See README gate. ----
# The consent screen MUST be "In production" or the refresh token dies every 7 days.
YT_CLIENT_ID=
YT_CLIENT_SECRET=
YT_REFRESH_TOKEN=

# ---- Render settings (optional overrides) ----
VOICE=af_heart
WIDTH=1920
HEIGHT=1080
FPS=30
TARGET_LEN_S=90
